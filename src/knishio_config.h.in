#pragma once

/**
 * KnishIO Client C++ SDK Configuration
 * This file is automatically generated by CMake
 */

#define KNISHIO_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define KNISHIO_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define KNISHIO_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define KNISHIO_VERSION "@PROJECT_VERSION@"

// Feature configuration
#cmakedefine01 KNISHIO_HTTP_SUPPORT

// Build configuration
#define KNISHIO_BUILD_TYPE "@CMAKE_BUILD_TYPE@"
#define KNISHIO_COMPILER "@CMAKE_CXX_COMPILER_ID@"

// Platform detection
#if defined(_WIN32) || defined(_WIN64)
    #define KNISHIO_PLATFORM_WINDOWS 1
#elif defined(__APPLE__)
    #define KNISHIO_PLATFORM_MACOS 1
#elif defined(__linux__)
    #define KNISHIO_PLATFORM_LINUX 1
#else
    #define KNISHIO_PLATFORM_UNKNOWN 1
#endif

// C++ standard version
#define KNISHIO_CXX_STANDARD @CMAKE_CXX_STANDARD@

// API macros
#if defined(KNISHIO_PLATFORM_WINDOWS) && defined(KNISHIO_SHARED_LIB)
    #ifdef KNISHIO_EXPORTS
        #define KNISHIO_API __declspec(dllexport)
    #else
        #define KNISHIO_API __declspec(dllimport)
    #endif
#else
    #define KNISHIO_API
#endif

// Namespace
namespace knishio {
    constexpr const char* version() { return KNISHIO_VERSION; }
    constexpr int version_major() { return KNISHIO_VERSION_MAJOR; }
    constexpr int version_minor() { return KNISHIO_VERSION_MINOR; }
    constexpr int version_patch() { return KNISHIO_VERSION_PATCH; }
}