# KnishIO Client C++ SDK CMake Configuration
#
# This file provides configuration for using the KnishIO Client C++ SDK
# in your CMake projects.
#
# Usage:
#   find_package(KnishIOClientCPP REQUIRED)
#   target_link_libraries(your_target KnishIO::ClientCPP)
#

@PACKAGE_INIT@

# Dependencies
include(CMakeFindDependencyMacro)

# Find libsodium
find_dependency(PkgConfig REQUIRED)
pkg_check_modules(SODIUM REQUIRED libsodium)

# Optional dependencies
if(@KNISHIO_HTTP_SUPPORT@)
    find_dependency(CURL REQUIRED)
endif()

# Include targets
if(NOT TARGET KnishIO::ClientCPP)
    include("${CMAKE_CURRENT_LIST_DIR}/KnishIOClientCPPTargets.cmake")
endif()

# Check that all required components are available
check_required_components(KnishIOClientCPP)

# Version information
set(KnishIOClientCPP_VERSION @PROJECT_VERSION@)
set(KnishIOClientCPP_VERSION_MAJOR @PROJECT_VERSION_MAJOR@)
set(KnishIOClientCPP_VERSION_MINOR @PROJECT_VERSION_MINOR@)
set(KnishIOClientCPP_VERSION_PATCH @PROJECT_VERSION_PATCH@)

# Feature information
set(KnishIOClientCPP_HTTP_SUPPORT @KNISHIO_HTTP_SUPPORT@)

# Provide information about available targets
if(NOT KnishIOClientCPP_FIND_QUIETLY)
    message(STATUS "Found KnishIO Client C++ SDK: ${KnishIOClientCPP_VERSION}")
    message(STATUS "  Available targets:")
    message(STATUS "    KnishIO::ClientCPP (shared library)")
    message(STATUS "    KnishIO::ClientCPP::Static (static library)")
    if(KnishIOClientCPP_HTTP_SUPPORT)
        message(STATUS "  HTTP client support: enabled")
    else()
        message(STATUS "  HTTP client support: disabled")
    endif()
endif()

# Usage example
if(NOT KnishIOClientCPP_FIND_QUIETLY)
    message(STATUS "")
    message(STATUS "KnishIO Client C++ SDK Usage:")
    message(STATUS "  find_package(KnishIOClientCPP REQUIRED)")
    message(STATUS "  target_link_libraries(your_target KnishIO::ClientCPP)")
    message(STATUS "")
endif()